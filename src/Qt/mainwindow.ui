<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
    <class>MainWindow</class>
    <widget class="QMainWindow" name="MainWindow">
        <property name="geometry">
            <rect>
                <x>0</x>
                <y>0</y>
                <width>1200</width> <!-- Increased window size for three columns -->
                <height>650</height>
            </rect>
        </property>
        <property name="windowTitle">
            <string>ANTLR AST &amp; Assembly Viewer</string>
        </property>
        <widget class="QWidget" name="centralwidget">
            <layout class="QHBoxLayout" name="horizontalLayout">

                <!-- Left Column: Source Editor -->
                <item>
                    <widget class="QPlainTextEdit" name="codeEditor">
                        <property name="plainText">
                            <string>1 + 2 + 3 + 4 + 5;</string>
                        </property>
                    </widget>
                </item>

                <!-- Second Column: AST Viewer -->
                <item>
                    <widget class="QTreeWidget" name="astTree">
                        <property name="headerLabels">
                            <stringlist>
                                <string>AST Structure</string>
                            </stringlist>
                        </property>
                    </widget>
                </item>

                <!-- Third Column: SSA Intermediate Representation Viewer -->
                <item>
                    <widget class="QPlainTextEdit" name="ssaViewer">
                        <property name="readOnly">
                            <bool>true</bool>
                        </property>
                        <property name="placeholderText">
                            <string>SSA Intermediate Representation...</string>
                        </property>
                    </widget>
                </item>
                
                <!-- Fourth Column: Unoptimized Assembly Output Viewer -->
                <item>
                    <widget class="QPlainTextEdit" name="plainAssemblyViewer">
                        <property name="readOnly">
                            <bool>true</bool> <!-- Prevent the user from typing over generated code -->
                        </property>
                        <property name="placeholderText">
                            <string>Target assembly code appears here...</string>
                        </property>
                    </widget>
                </item>

                <!-- Fifth Column: Optimized Assembly Output Viewer -->
                <item>
                    <widget class="QPlainTextEdit" name="optimizedAssemblyViewer">
                        <property name="readOnly">
                            <bool>true</bool> <!-- Prevent the user from typing over generated code -->
                        </property>
                        <property name="placeholderText">
                            <string>Target assembly code appears here...</string>
                        </property>
                    </widget>
                </item>

            </layout>
        </widget>
    </widget>
</ui>
